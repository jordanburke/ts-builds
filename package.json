{
  "name": "ts-builds",
  "version": "2.8.1",
  "description": "Shared TypeScript configuration files for library templates. Provides standardized ESLint, Prettier, Vitest, TypeScript, and build configs.",
  "keywords": [
    "typescript",
    "template",
    "config",
    "eslint",
    "prettier",
    "vitest",
    "tsdown",
    "vite",
    "shared-config"
  ],
  "author": "jordan.burke@gmail.com",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/jordanburke/ts-builds",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jordanburke/ts-builds.git"
  },
  "main": "./prettier-config.cjs",
  "bin": {
    "ts-builds": "dist/cli.js"
  },
  "exports": {
    ".": "./prettier-config.cjs",
    "./prettier": "./prettier-config.cjs",
    "./prettier-ignore": "./.prettierignore",
    "./eslint": "./eslint.config.base.js",
    "./eslint-fp": "./eslint.config.fp.js",
    "./eslint-functype": "./eslint.config.functype.js",
    "./vitest": "./dist/vitest.config.base.js",
    "./tsconfig": "./tsconfig.base.json",
    "./tsdown": "./dist/tsdown.config.base.js",
    "./vite": "./dist/vite.config.base.js",
    "./scripts": "./package-scripts.json",
    "./package.json": "./package.json"
  },
  "files": [
    "prettier-config.cjs",
    ".prettierignore",
    "eslint.config.base.js",
    "eslint.config.fp.js",
    "eslint.config.functype.js",
    "dist",
    "tsconfig.base.json",
    "package-scripts.json",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "~24.10.15",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/ui": "^4.1.6",
    "eslint": "^10.4.0",
    "eslint-config-functype": "^2.60.7",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-functype": "^2.60.7",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "functype": "^0.60.7",
    "functype-os": "^0.60.7",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.6"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "tsdown": "^0.22.0"
  },
  "peerDependencies": {
    "tsdown": "^0.x",
    "vite": "^8.x"
  },
  "peerDependenciesMeta": {
    "tsdown": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "scripts": {
    "bootstrap": "rimraf dist && tsdown",
    "validate": "node dist/cli.js validate",
    "validate:bootstrap": "pnpm bootstrap && pnpm validate",
    "format": "node dist/cli.js format",
    "format:check": "node dist/cli.js format:check",
    "lint": "node dist/cli.js lint",
    "lint:check": "node dist/cli.js lint:check",
    "typecheck": "node dist/cli.js typecheck",
    "test": "node dist/cli.js test",
    "test:watch": "vitest",
    "build": "node dist/cli.js build",
    "dev": "node dist/cli.js dev",
    "prepublishOnly": "pnpm validate:bootstrap"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint": "10"
      }
    },
    "overrides": {
      "unrun": "0.2.37"
    }
  },
  "packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800"
}
